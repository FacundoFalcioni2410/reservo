generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  admin
  professional
  client
}

enum BookingStatus {
  pending
  confirmed
  cancelled
  completed
}

enum EmailTemplateType {
  invite
  booking_confirmation
}

enum RecurrenceType {
  ONCE
  WEEKLY
}

enum AttendeeStatus {
  PENDING_CONFIRMATION
  CONFIRMED
  WAITLISTED
  CANCELLED
}

model Tenant {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  logoUrl     String?
  phone       String?
  description String?
  openTime    Int       @default(8)
  closeTime   Int       @default(20)
  workingDays Int       @default(62)  // bitmask: bit0=Dom...bit6=Sáb, 62=Lun-Vie
  createdAt   DateTime  @default(now())
  users          User[]
  branches       Branch[]
  bookings       Booking[]
  services       Service[]
  emailTemplates EmailTemplate[]
  blackouts      BlackoutDate[]
  events         Event[]
}

model Branch {
  id            String    @id @default(cuid())
  name          String
  address       String?
  phone         String?
  openTime      Int?
  closeTime     Int?
  workingDays   Int?      // nullable override; null = inherit from tenant
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id])
  bookings      Booking[]
  professionals User[]    @relation("ProfessionalBranches")
  services      Service[] @relation("BranchServices")
  createdAt     DateTime  @default(now())
}

model User {
  id                   String    @id @default(cuid())
  email                String    @unique
  passwordHash         String?
  inviteToken          String?   @unique
  inviteExpiry         DateTime?
  role                 Role      @default(client)
  tenantId             String?
  tenant               Tenant?   @relation(fields: [tenantId], references: [id])
  bookings             Booking[] @relation("ProfessionalBookings")
  branches             Branch[]  @relation("ProfessionalBranches")
  services             Service[] @relation("ProfessionalServices")
  schedule             ProfessionalSchedule[] @relation("ProfessionalSchedule")
  blackouts            BlackoutDate[]         @relation("ProfessionalBlackouts")
  events               Event[]   @relation("EventProfessionals")
  occurrenceEntries    EventOccurrenceProfessional[] @relation("OccurrenceProfessionals")
  googleAccessToken    String?
  googleRefreshToken   String?
  createdAt            DateTime  @default(now())
}

model Service {
  id            String    @id @default(cuid())
  name          String
  description   String?
  price         Decimal?
  imageUrl      String?
  duration      Int       @default(60)
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id])
  professionals User[]    @relation("ProfessionalServices")
  branches      Branch[]  @relation("BranchServices")
  bookings      Booking[]
  createdAt     DateTime  @default(now())
}

model EmailTemplate {
  id        String            @id @default(cuid())
  tenantId  String
  type      EmailTemplateType
  subject   String
  body      String
  tenant    Tenant            @relation(fields: [tenantId], references: [id])
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@unique([tenantId, type])
}

model ProfessionalSchedule {
  id             String  @id @default(cuid())
  professionalId String
  professional   User    @relation("ProfessionalSchedule", fields: [professionalId], references: [id], onDelete: Cascade)
  dayOfWeek      Int     // 0=Dom, 1=Lun, ..., 6=Sáb
  isWorkingDay   Boolean @default(true)
  startHour      Int     @default(8)
  endHour        Int     @default(20)

  @@unique([professionalId, dayOfWeek])
}

model BlackoutDate {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id])
  professionalId String?
  professional   User?    @relation("ProfessionalBlackouts", fields: [professionalId], references: [id], onDelete: Cascade)
  startDate      DateTime
  endDate        DateTime
  reason         String?
  createdAt      DateTime @default(now())
}

model Event {
  id              String          @id @default(cuid())
  tenantId        String
  title           String
  description     String?
  imageUrl        String?
  location        String?
  durationMinutes Int             @default(60)
  maxAttendees    Int
  time            String          // "HH:mm"
  recurrenceType  RecurrenceType  @default(ONCE)
  recurrenceDays  Int             @default(0) // bitmask, solo para WEEKLY (bit0=Dom...bit6=Sáb)
  startDate       DateTime        // para ONCE: la fecha; para WEEKLY: inicio de la serie
  endDate         DateTime?       // para WEEKLY: fin opcional de la serie
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  occurrences     EventOccurrence[]
  professionals   User[]          @relation("EventProfessionals")
}

model EventOccurrence {
  id               String          @id @default(cuid())
  eventId          String
  date             DateTime        // fecha concreta de la ocurrencia (sin hora)
  isCancelled      Boolean         @default(false)
  event            Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  attendees        EventAttendee[]
  professionalEntries EventOccurrenceProfessional[]

  @@unique([eventId, date])
}

model EventOccurrenceProfessional {
  id                    String          @id @default(cuid())
  occurrenceId          String
  professionalId        String
  googleCalendarEventId String?
  occurrence            EventOccurrence @relation(fields: [occurrenceId], references: [id], onDelete: Cascade)
  professional          User            @relation("OccurrenceProfessionals", fields: [professionalId], references: [id], onDelete: Cascade)

  @@unique([occurrenceId, professionalId])
}

model EventAttendee {
  id                 String         @id @default(cuid())
  occurrenceId       String
  clientName         String
  clientEmail        String
  clientPhone        String?
  status             AttendeeStatus @default(PENDING_CONFIRMATION)
  cancellationToken  String         @unique @default(cuid())
  confirmationToken  String         @unique @default(cuid())
  expiresAt          DateTime?      // para PENDING_CONFIRMATION: 1h desde registeredAt
  registeredAt       DateTime       @default(now())
  occurrence         EventOccurrence @relation(fields: [occurrenceId], references: [id], onDelete: Cascade)
}

model Booking {
  id             String        @id @default(cuid())
  tenantId       String
  tenant         Tenant        @relation(fields: [tenantId], references: [id])
  branchId       String?
  branch         Branch?       @relation(fields: [branchId], references: [id], onDelete: SetNull)
  professionalId String?
  professional   User?         @relation("ProfessionalBookings", fields: [professionalId], references: [id], onDelete: SetNull)
  serviceId      String?
  service        Service?      @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  clientName     String
  clientPhone    String?
  clientEmail    String?
  serviceName    String?
  startTime      DateTime
  endTime        DateTime
  status         BookingStatus @default(pending)
  notes                  String?
  googleCalendarEventId  String?
  createdAt              DateTime      @default(now())
}
